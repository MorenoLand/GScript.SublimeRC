%YAML 1.2
---
name: RC PM
scope: text.rc-pm
contexts:
  main:
    - match: '^(Private Messages for )(.*)$'
      captures:
        1: constant.language
        2: entity.name.function
    - match: '^([A-Z][a-z]+ \d+(?:st|nd|rd|th) \d{4}, at \d{1,2}:\d{2}(?:am|pm)) (From|To) ([^:]+)(:)'
      captures:
        1: constant.language
        2: constant.language
        3: entity.name.function
        4: entity.name.function
    - match: '^(> )'
      captures:
        1: constant.language
